ntax-table)    (modify-syntax-entry ?- "w" prs-mode-syntax-table)    (modify-syntax-entry ?^ "w" prs-mode-syntax-table)    (modify-syntax-entry ?_ "w" prs-mode-syntax-table)    (modify-syntax-entry ?~ "w" prs-mode-syntax-table)    (modify-syntax-entry ?: "w" prs-mode-syntax-table)    (modify-syntax-entry ?; "w" prs-mode-syntax-table)    (modify-syntax-entry ?! "w" prs-mode-syntax-table)    (modify-syntax-entry ?? "w" prs-mode-syntax-table)    (modify-syntax-entry ?, "w" prs-mode-syntax-table)    (modify-syntax-entry ?@ "w" prs-mode-syntax-table)    (modify-syntax-entry ?\( "()  " prs-mode-syntax-table)    (modify-syntax-entry ?\) ")(  " prs-mode-syntax-table)    (modify-syntax-entry ?\{ "(}  " prs-mode-syntax-table)    (modify-syntax-entry ?\} "){  " prs-mode-syntax-table)    (modify-syntax-entry ?\[ "(]  " prs-mode-syntax-table)    (modify-syntax-entry ?\] ")[  " prs-mode-syntax-table));;; Variables for the mode(defun prs-mode-variables ()  ;; Turn on fonts in different colors.  (add-hook 'prs-mode-hook 'turn-on-font-lock)  (make-local-variable 'font-lock-defaults)  (setq font-lock-defaults '(prs-font-lock-keywords nil nil ((?_ . "w"))))  ;; Blink matching parentheses.  (make-local-variable 'blink-matching-paren)  (setq blink-matching-paren t)  ;; Turn off auto-fill.  (make-local-variable 'auto-fill-function)  (setq auto-fill-function nil)  (run-hooks 'prs-mode-hook));;; THK: Always want t for PRS mode(defvar prs-more-colors t    "If t, gives more colors.  If set to nil, only comments appear in color.")(if prs-more-colors   ; If the user wants more colors, add them.   (setq prs-font-lock-keywords     ; (union ;prs-font-lock-keywords        ; (list	  ; (cons "^[ \t]*\#\.*$" 'font-lock-string-face))       (list           (cons "^[ \t]*\#\.*$" 'font-lock-string-face)	 ; THK:  template names          (list "^[ \t]*\\([A-Za-z_-]+\\)\(\.*\)[ \t]*::" 1 'font-lock-variable-name-face)	 ; THK:  macro names          (list "^[ \t]*\\([A-Za-z_-]+\\)\(\.*\)[ \t]*:=" 1 'font-lock-variable-name-face)          ; Highlight at signs	 (cons "@" 'font-lock-variable-name-face)         ; THK: non-resourced          (cons "/-" 'font-lock-constant-face)         ; THK: highlight %% variables differently          (cons "\%\%"  'font-lock-variable-name-face)         ; THK: highlight variables          (list "\\(%[^., \)><%]+\\)[,\) \t\n><.]" 1 'font-lock-keyword-face)	 ; Highlight open and close brackets and vertical bars	 (cons "[}{|]" 'font-lock-constant-face)))) ;)(defun prs-in-comment (bufferpos config-pos)  "Use sexp parser to determine whether we are in or out of a comment."  (save-match-data     (save-excursion     (goto-char config-pos)     (nth 3 (parse-partial-sexp config-pos bufferpos)))))